# Local Issue 001 verification only. Replace every token outside local development.
ONECOMPUTER_WEB_PROXY_TOKEN=replace-with-at-least-24-characters
ONECOMPUTER_CONTROLLER_TOKEN=replace-with-at-least-24-characters
ONECOMPUTER_POSTGRES_PASSWORD=replace-with-a-local-password

# Issue 002 LiteLLM qualification slice. The master key stays in Control.
ONECOMPUTER_LITELLM_MASTER_KEY=sk-replace-with-at-least-24-characters
ONECOMPUTER_LITELLM_CREDENTIAL_SECRET=replace-with-at-least-32-random-characters
ONECOMPUTER_LITELLM_POSTGRES_PASSWORD=replace-with-a-separate-local-password
ONECOMPUTER_LITELLM_UI_USERNAME=admin
ONECOMPUTER_LITELLM_UI_PASSWORD=replace-the-loopback-only-development-password
ONECOMPUTER_FIXTURE_APPROVAL_SECRET=replace-with-at-least-32-random-characters

# Issue 008 Softeria Microsoft 365 connector. The client and tenant IDs are
# public identifiers; never commit the optional confidential-client secret.
ONECOMPUTER_MS365_CLIENT_ID=replace-with-dedicated-entra-application-client-id
ONECOMPUTER_MS365_TENANT_ID=replace-with-entra-directory-tenant-id
ONECOMPUTER_MS365_CLIENT_SECRET=provide-through-an-approved-runtime-secret-store

# Production Kasm Developer API adapter (SANDBOX_DRIVER=kasm).
KASM_BASE_URL=https://kasm.example.com
KASM_API_KEY=replace-from-secret-store
KASM_API_SECRET=replace-from-secret-store
KASM_USER_ID=replace-with-service-user-id
KASM_IMAGE_ID=replace-with-approved-image-id

# Local pinned KasmVNC adapter from the experimentation branch reference.
SANDBOX_DRIVER=kasm-local
KASM_LOCAL_NETWORK=onecomputer-v4-sandbox
KASM_LOCAL_CONTROL_NETWORK=onecomputer-v4-control
KASM_PUBLIC_HOST=127.0.0.1
