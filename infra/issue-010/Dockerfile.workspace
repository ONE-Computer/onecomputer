FROM kasmweb/ubuntu-jammy-desktop@sha256:58b0710b320b99ab7e352342d7ec3a25b09740c523b75d794c5f7476910da580

USER root

ARG CLAUDE_DESKTOP_VERSION=1.22209.3
ARG CLAUDE_DESKTOP_SHA256=d427f46ac9233dbc4d8a441a602f09f750b8a5f05d1fc7a00285d7a6ce07655c

RUN export DEBIAN_FRONTEND=noninteractive \
    && apt-get purge -y \
      code firefox gimp gimp-data google-chrome-stable \
      nextcloud-desktop nextcloud-desktop-common nextcloud-desktop-doc nextcloud-desktop-l10n \
      obs-studio obs-v4l2sink onlyoffice-desktopeditors \
      remmina remmina-common remmina-plugin-rdp remmina-plugin-secret remmina-plugin-spice remmina-plugin-vnc \
      signal-desktop slack-desktop sublime-text thunderbird zoom \
    && apt-get autoremove -y \
    && curl -fsSLo /tmp/claude-desktop.deb \
      "https://downloads.claude.ai/claude-desktop/apt/stable/pool/main/c/claude-desktop/claude-desktop_${CLAUDE_DESKTOP_VERSION}_amd64.deb" \
    && echo "${CLAUDE_DESKTOP_SHA256}  /tmp/claude-desktop.deb" | sha256sum -c - \
    && apt-get update \
    && apt-get install -y --no-install-recommends /tmp/claude-desktop.deb \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/claude-desktop.deb /opt/Telegram \
      /home/kasm-default-profile/Desktop/* \
      /home/kasm-default-profile/.mozilla \
      /home/kasm-default-profile/.local/share/remmina \
    && install -d -o root -g root -m 0755 /etc/claude-desktop /run/onecomputer

COPY infra/issue-010/onecomputer-gateway-proxy.py /usr/local/libexec/onecomputer-gateway-proxy
COPY infra/issue-010/onecomputer-workspace-entrypoint.sh /usr/local/sbin/onecomputer-workspace-entrypoint
COPY infra/issue-010/claude-desktop.desktop /usr/share/applications/onecomputer-claude-desktop.desktop
COPY infra/issue-010/claude-desktop.desktop /home/kasm-default-profile/Desktop/Claude-Desktop.desktop
COPY infra/issue-010/claude-desktop.desktop /home/kasm-default-profile/.config/autostart/claude-desktop.desktop

RUN chmod 0755 \
      /usr/local/libexec/onecomputer-gateway-proxy \
      /usr/local/sbin/onecomputer-workspace-entrypoint \
      /usr/share/applications/onecomputer-claude-desktop.desktop \
      /home/kasm-default-profile/Desktop/Claude-Desktop.desktop \
      /home/kasm-default-profile/.config/autostart/claude-desktop.desktop \
    && chown -R 1000:1000 /home/kasm-default-profile/Desktop /home/kasm-default-profile/.config

HEALTHCHECK --interval=5s --timeout=2s --start-period=15s --retries=12 \
  CMD curl -fsS http://127.0.0.1:4312/healthz || exit 1

USER root
ENTRYPOINT ["/usr/local/sbin/onecomputer-workspace-entrypoint"]
CMD ["--tail-log"]
