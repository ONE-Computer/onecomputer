{
  "provider": "@softeria/ms-365-mcp-server",
  "version": "0.131.2",
  "litellmVersion": "1.93.0",
  "serverName": "onecomputer_ms365",
  "serverId": "9885e7f76089931fc5365104183af8ea",
  "schemaContract": "apps/control-api/src/mcp-policy.ts",
  "policyCatalog": "packages/contracts/src/index.ts#m365ToolCatalog",
  "scopes": [
    "User.Read", "offline_access", "Mail.ReadWrite", "Mail.Send", "Calendars.ReadWrite", "Files.ReadWrite",
    "Chat.Read", "ChatMessage.Read", "ChatMessage.Send", "Team.ReadBasic.All", "Channel.ReadBasic.All",
    "ChannelMessage.Read.All", "ChannelMessage.Send"
  ],
  "defaultAllow": [
    "list-mail-folders", "list-mail-messages", "get-mail-message", "list-calendars", "list-calendar-events",
    "get-calendar-event", "list-drives", "get-drive-root-item", "list-folder-files", "search-onedrive-files",
    "get-drive-item", "list-chats", "list-chat-messages", "list-joined-teams", "list-team-channels",
    "list-channel-messages"
  ],
  "defaultApprovalRequired": [
    "create-draft-email", "update-mail-message", "delete-mail-message", "move-mail-message", "send-mail",
    "send-draft-message", "reply-mail-message", "reply-all-mail-message", "forward-mail-message",
    "create-calendar-event", "update-calendar-event", "delete-calendar-event", "create-onedrive-folder",
    "upload-file-content", "move-rename-onedrive-item", "copy-drive-item", "delete-onedrive-file",
    "send-chat-message", "reply-to-chat-message", "send-channel-message", "reply-to-channel-message"
  ],
  "executionFlagsOwnedByControl": ["confirm", "excludeResponse"],
  "requalifyWhen": [
    "LiteLLM image/version or MCP dispatcher hook path changes",
    "Softeria package/version, tool name, input schema, or confirmation behavior changes",
    "server name, URL, transport, authentication type, scopes, or stable server ID changes",
    "owned argument projection, schema ID/hash, result projection, or policy callback changes"
  ]
}
