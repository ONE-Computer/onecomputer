{
  "$schema": "https://v2-7-6.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "NEXT_PUBLIC_EDITION"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "EDITION",
    "APP_URL",
    "API_URL",
    "COGNITO_CLIENT_ID",
    "COGNITO_DOMAIN",
    "COGNITO_USER_POOL_ID",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "NEXT_PUBLIC_COGNITO_USER_POOL_ID",
    "NEXT_PUBLIC_COGNITO_CLIENT_ID",
    "NEXT_PUBLIC_COGNITO_DOMAIN",
    "AWS_REGION",
    "NEXT_RUNTIME",
    "STRIPE_SECRET_KEY",
    "STRIPE_PRO_PRICE_ID",
    "STRIPE_TEAM_BASE_PRICE_ID",
    "STRIPE_PRO_AGENT_ADDON_PRICE_ID",
    "STRIPE_TEAM_AGENT_ADDON_PRICE_ID",
    "STRIPE_WEBHOOK_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "OAUTH_STATE_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "SECRET_ENCRYPTION_KEY",
    "HOME",
    "GATEWAY_CA_PEM_FILE",
    "GATEWAY_CA_CERT",
    "KMS_KEY_ARN",
    "API_DOMAIN",
    "GATEWAY_API_DOMAIN",
    "GATEWAY_API_URL",
    "NEXT_PUBLIC_GATEWAY_API_URL",
    "GATEWAY_BASE_URL",
    "INTERNAL_API_URL",
    "GATEWAY_INTERNAL_SECRET",
    "DEMO_MODE",
    "SEED_DEMO_RESET",
    "LOG_LEVEL",
    "LOG_FORMAT",
    "AUTH_MODE",
    "OPENVTC_RP_DID",
    "OPENVTC_APPROVER_DID",
    "NEXT_PUBLIC_OPENVTC_RP_DID",
    "OPENVTC_SESSION_SECRET",
    "MAILERCHECK_API_KEY",
    "DISCORD_WEBHOOK_URL",
    "DISCORD_REVIEW_WEBHOOK_URL",
    "ENVIRONMENT",
    "RESEND_API_KEY",
    "NEXT_PUBLIC_API_URL",
    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_USERNAME",
    "REDIS_PASSWORD",
    "CRON_SECRET_NAME",
    "ANTHROPIC_SECRET_NAME",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "NOTION_CLIENT_ID",
    "NOTION_CLIENT_SECRET",
    "DROPBOX_CLIENT_ID",
    "DROPBOX_CLIENT_SECRET",
    "SUPABASE_CLIENT_ID",
    "SUPABASE_CLIENT_SECRET",
    "ZOOM_CLIENT_ID",
    "ZOOM_CLIENT_SECRET",
    "LINKEDIN_CLIENT_ID",
    "LINKEDIN_CLIENT_SECRET",
    "TRELLO_API_KEY",
    "TRELLO_API_SECRET",
    "MONDAY_CLIENT_ID",
    "MONDAY_CLIENT_SECRET",
    "SENTRY_CLIENT_ID",
    "SENTRY_CLIENT_SECRET",
    "HUBSPOT_CLIENT_ID",
    "HUBSPOT_CLIENT_SECRET",
    "LINEAR_CLIENT_ID",
    "LINEAR_CLIENT_SECRET",
    "RUST_LOG",
    "PORT",
    "ATLASSIAN_CLIENT_ID",
    "ATLASSIAN_CLIENT_SECRET",
    "INVGINI_EVENTS_FIXTURE",
    "GOVERNED_ACTION_GATEWAY_URL",
    "GOVERNED_ACTION_AGENT_TOKEN",
    "ONECLI_GATEWAY_SIGNING_KEY",
    "ONECLI_GATEWAY_PUBLIC_URL",
    "ONECOMPUTER_ENV",
    "PUBLIC_WEB_ORIGIN",
    "AZURE_CLIENT_ID",
    "AZURE_CLIENT_SECRET",
    "AZURE_TENANT_ID",
    "DAYTONA_API_URL",
    "DAYTONA_API_KEY",
    "DAYTONA_PROXY_URL",
    "DAYTONA_SNAPSHOT",
    "VERDACCIO_URL",
    "GATEWAY_PROXY_URL",
    "DAYTONA_DESKTOP_URL_TEMPLATE",
    "DAYTONA_DESKTOP_BASE_URL",
    "SANDBOX_PROVIDER",
    "KASM_DESKTOP_IMAGE",
    "KASM_CONTAINER_PREFIX",
    "KASM_PORT_START",
    "KASM_PORT_END",
    "KASM_VNC_PASSWORD",
    "ONECOMPUTER_LLM_PROXY_MODE",
    "ONECOMPUTER_LLM_PROXY_BASE_URL",
    "ONECOMPUTER_LLM_PROXY_MODELS",
    "ONECOMPUTER_LLM_PROXY_LOG_HINT",
    "ONECOMPUTER_LLM_PROXY_API_KEY",
    "ONECOMPUTER_LLM_PROXY_AUTH_SCHEME",
    "ONECOMPUTER_CLAUDE_DESKTOP_GATEWAY_BASE_URL",
    "ONECOMPUTER_SANDBOX_ENABLE_DOCKER",
    "LITELLM_MASTER_KEY",
    "KASM_PUBLIC_HOST",
    "KASM_PUBLIC_SCHEME",
    "AUTH_URL",
    "ONECOMPUTER_E2E_DEMO_AUTH",
    "AZURE_AD_CLIENT_ID",
    "AZURE_AD_CLIENT_SECRET",
    "AZURE_AD_TENANT_ID",
    "E2E_GRAPH_LIVE",
    "OPENVTC_APPROVAL_API_URL",
    "OPENVTC_WALLET_PENDING_DIR",
    "OPENVTC_WALLET_SCRIPT",
    "OPENVTC_TRANSPORT_BINDING",
    "OPENVTC_TASK_ENDPOINT_URL",
    "OPENVTC_TASK_ENDPOINT_BEARER",
    "OPENVTC_TEST_WALLET_URL",
    "OPENVTC_TEST_WALLET_HOST",
    "OPENVTC_TEST_WALLET_PORT",
    "OPENVTC_TEST_WALLET_SEED",
    "OPENVTC_TEST_WALLET_SEED_FILE",
    "ONECOMPUTER_E2E_PROJECT_ID",
    "ONECOMPUTER_E2E_AGENT",
    "ONECOMPUTER_TEST_MODE",
    "ONECOMPUTER_TEST_INJECT_ALLOCATION_RESPONSE_FAILURE_ONCE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@onecli/gateway#build": {
      "inputs": ["src/**", "Cargo.toml", "Cargo.lock"],
      "outputs": ["target/release/**"]
    },
    "@onecli/gateway#dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "EDITION",
        "DATABASE_URL",
        "SECRET_ENCRYPTION_KEY",
        "KMS_KEY_ARN",
        "AWS_REGION",
        "REDIS_HOST",
        "REDIS_PORT",
        "REDIS_PASSWORD",
        "REDIS_TLS",
        "COGNITO_USER_POOL_ID",
        "POSTHOG_API_KEY",
        "POSTHOG_HOST",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "NOTION_CLIENT_ID",
        "NOTION_CLIENT_SECRET",
        "DROPBOX_CLIENT_ID",
        "DROPBOX_CLIENT_SECRET",
        "SUPABASE_CLIENT_ID",
        "SUPABASE_CLIENT_SECRET",
        "ZOOM_CLIENT_ID",
        "ZOOM_CLIENT_SECRET",
        "LINKEDIN_CLIENT_ID",
        "LINKEDIN_CLIENT_SECRET",
        "MONDAY_CLIENT_ID",
        "MONDAY_CLIENT_SECRET",
        "SENTRY_CLIENT_ID",
        "SENTRY_CLIENT_SECRET",
        "HUBSPOT_CLIENT_ID",
        "HUBSPOT_CLIENT_SECRET",
        "LINEAR_CLIENT_ID",
        "LINEAR_CLIENT_SECRET"
      ]
    },
    "@onecli/gateway#check": {
      "inputs": ["src/**", "Cargo.toml"]
    },
    "@onecli/gateway#check-types": {
      "inputs": ["src/**", "Cargo.toml", "Cargo.lock"],
      "outputs": []
    },
    "@onecli/gateway#lint": {
      "inputs": ["src/**", "Cargo.toml"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "test": {
      "cache": false
    },
    "@onecli/gateway#test": {
      "inputs": ["src/**", "tests/**", "Cargo.toml", "Cargo.lock"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
