ONECOMPUTER_WEB_PROXY_TOKEN=local-qualification-only-123456789
ONECOMPUTER_CONTROLLER_TOKEN=local-qualification-only-123456789
ONECOMPUTER_POSTGRES_PASSWORD=local-qualification-only

ONECOMPUTER_LITELLM_MASTER_KEY=sk-local-qualification-only-123456789
ONECOMPUTER_LITELLM_SALT_KEY=replace-with-a-stable-dedicated-random-secret
ONECOMPUTER_LITELLM_CREDENTIAL_SECRET=local-qualification-only-123456789
ONECOMPUTER_LITELLM_POSTGRES_PASSWORD=local-qualification-only
ONECOMPUTER_LITELLM_UI_USERNAME=admin
ONECOMPUTER_LITELLM_UI_PASSWORD=onecomputer-local-admin
ONECOMPUTER_FIXTURE_APPROVAL_SECRET=local-qualification-only-123456789
# Stable Ed25519 PKCS8 key for signed OpenVTC task-consent requests.
# Generate once with: npm run key:openvtc
ONECOMPUTER_OPENVTC_EXECUTOR_PRIVATE_KEY_B64=replace-with-generated-base64-pkcs8-key
# Provider credentials are injected into LiteLLM only. Workspaces receive a
# revocable virtual key restricted to the model alias selected by policy.
ONECOMPUTER_OPENAI_API_KEY=provide-through-an-approved-runtime-secret-store
ONECOMPUTER_CLAUDE_API_KEY=provide-through-an-approved-runtime-secret-store
ONECOMPUTER_GLM_API_KEY=provide-through-an-approved-runtime-secret-store
ONECOMPUTER_PUBLIC_WEB_URL=http://localhost:4174
ONECOMPUTER_LITELLM_PUBLIC_URL=http://localhost:4000
ONECOMPUTER_M365_AUTHORIZATION_ORIGIN=http://localhost:4311

# ONEComputer Web sign-in. The same single-tenant app may be reused locally;
# register http://localhost:4174/api/v1/auth/callback as an additional Web URI.
ONECOMPUTER_ENTRA_TENANT_ID=replace-with-entra-directory-tenant-id
ONECOMPUTER_ENTRA_CLIENT_ID=replace-with-dedicated-entra-application-client-id
ONECOMPUTER_ENTRA_CLIENT_SECRET=provide-through-an-approved-runtime-secret-store
ONECOMPUTER_SESSION_SECRET=replace-with-a-stable-dedicated-32-byte-random-secret
ONECOMPUTER_BOOTSTRAP_TENANT_ID=acme
ONECOMPUTER_BOOTSTRAP_USER_ID=alex-morgan
ONECOMPUTER_TENANT_DISPLAY_NAME=ME TECH
ONECOMPUTER_ADMINISTRATOR_EMAILS=mike@metech.dev

SANDBOX_DRIVER=kasm-local
ONECOMPUTER_WORKSPACE_IMAGE=sha256:replace-with-the-local-issue-010-image-id
KASM_LOCAL_NETWORK_PREFIX=onecomputer-v4-ws
KASM_LOCAL_CONTROL_NETWORK=onecomputer-v4-control
KASM_LOCAL_GATEWAY_CONTAINER=onecomputer-v4-litellm
KASM_LOCAL_CONTROL_CONTAINER=onecomputer-v4-issue-002-control-api-1
KASM_PUBLIC_HOST=127.0.0.1

ONECOMPUTER_MS365_CLIENT_ID=replace-with-dedicated-entra-application-client-id
ONECOMPUTER_MS365_TENANT_ID=replace-with-entra-directory-tenant-id
ONECOMPUTER_MS365_CLIENT_SECRET=provide-through-an-approved-runtime-secret-store

# Production Kasm Developer API adapter (SANDBOX_DRIVER=kasm).
KASM_BASE_URL=https://kasm.example.com
KASM_API_KEY=replace-from-secret-store
KASM_API_SECRET=replace-from-secret-store
KASM_USER_ID=replace-with-service-user-id
KASM_IMAGE_ID=replace-with-approved-image-id
